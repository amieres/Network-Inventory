{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning"
        },
        "ConsoleThemeType": "Ansi"
    },
    "HomeAssistant": {
        "Host": "192.168.1.x",
        "Port": 8123,
        "Ssl": false,
        "Token": "YOUR_HA_LONG_LIVED_TOKEN"
    },
    "NetDaemon": {
        "ApplicationConfigurationFolder": "./yaml"
    },
    "CodeGeneration": {
        "Namespace": "HomeAssistantGenerated",
        "OutputFile": "HomeAssistantGenerated.cs",
        "UseAttributeBaseClasses": "false"
    },
    "Kestrel": {
        "Endpoints": {
            "Http": { "Url": "http://0.0.0.0:10000" }
        }
    },
    "NetworkInventory": {
        "DbPath": "/config/devices.db",
        "Subnets": [ "192.168.1" ],
        "ScanInterval": 5,
        "CleanupMaxAgeMinutes": 240,
        "PingTimeout": 500,
        "Netgear": {
            "Host": "http://192.168.1.1",
            "Password": "YOUR_ROUTER_ADMIN_PASSWORD"
        },
        "Eero": {
            "Enabled": false,
            "SessionCookie": "YOUR_EERO_SESSION_COOKIE",
            "NetworkId": "YOUR_EERO_NETWORK_ID"
        },
        "Debug": {
            "Netgear": false,
            "Eero": false,
            "Bermuda": false
        }
    }
}
